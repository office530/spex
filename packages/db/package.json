{
  "name": "@spex/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Drizzle ORM schema + migrations for Spex (PostgreSQL via Supabase)",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "lint": "echo '[db] lint not yet scaffolded' && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "echo '[db] tests not yet scaffolded' && exit 0",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1"
  }
}
