{
  "name": "@spex/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Spex frontend — React 18 + Vite + TypeScript (RTL Hebrew-first)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "echo '[web] lint not yet scaffolded' && exit 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@spex/ui": "workspace:*",
    "@supabase/supabase-js": "^2.104.0",
    "@tanstack/react-query": "^5.100.2",
    "@tanstack/react-table": "^8.21.3",
    "cmdk": "^1.1.1",
    "i18next": "^23.16.4",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
