# Copy to .env and fill in. Never commit .env.

# Database (Supabase Postgres — direct connection, server-side/migrations only)
DATABASE_URL=postgres://postgres:[password]@db.vxzflohvtfrkwycpaxiy.supabase.co:5432/postgres

# Supabase project: vxzflohvtfrkwycpaxiy (ap-southeast-1 Singapore)
SUPABASE_URL=https://vxzflohvtfrkwycpaxiy.supabase.co
# Publishable key (safe for browser) — use sb_publishable_... format
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Anon key (legacy JWT — interchangeable with publishable key for client-side use)
SUPABASE_ANON_KEY=
# Service-role key (full DB access — server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Vite browser env (must be prefixed VITE_)
VITE_SUPABASE_URL=https://vxzflohvtfrkwycpaxiy.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Node runtime
NODE_ENV=development
